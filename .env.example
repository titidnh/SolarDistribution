# ── Variables d'environnement pour docker-compose ─────────────────────────────
# Copier ce fichier en .env et adapter les valeurs
# Ne pas committer .env dans git !

# ── Base de données
DB_ROOT_PASSWORD=changeme_root
DB_PASSWORD=changeme_solar

# ── Timezone
TZ=Europe/Brussels

# ── API
API_PORT=8080

# ── Swagger API Key
# Mettre SWAGGER_APIKEY_ENABLED=true pour protéger Swagger avec une clé
SWAGGER_APIKEY_ENABLED=false
SWAGGER_APIKEY_KEY=changeme_swagger_key

# ── CORS
CORS_ALLOW_ANY=false
CORS_ORIGIN_0=http://localhost:3000
CORS_ORIGIN_1=http://localhost:5173

